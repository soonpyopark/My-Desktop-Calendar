<Window x:Class="MyDesktopCalendar.DesktopHostWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="My Desktop Calendar Host"
        Width="1536"
        Height="864"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#202124"
        BorderThickness="0"
        ShowInTaskbar="False"
        ShowActivated="False"
        AllowsTransparency="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
  <Grid>
    <wv2:WebView2 x:Name="WebView" DefaultBackgroundColor="#FF202124" />
  </Grid>
</Window>
