<Window x:Class="MyDesktopCalendar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="My Desktop Calendar"
        Width="1536"
        Height="864"
        MinWidth="640"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#EEF0F2"
        BorderThickness="0"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
  <Grid Background="#EEF0F2">
    <!-- Opaque page tint — Transparent clear showed black gaps and white flashes. -->
    <wv2:WebView2 x:Name="WebView" DefaultBackgroundColor="#FFEEF0F2" />
    <!-- While resizing: solid cover over a size-pinned WebView (layout deferred until mouse-up). -->
    <Border x:Name="ResizeGhost"
            Background="#EEF0F2"
            Visibility="Collapsed"
            IsHitTestVisible="False"
            Panel.ZIndex="5" />
    <!-- Brief boot splash only (not the wallpaper surface clear color). -->
    <Border x:Name="BootSplash"
            Background="#EEF0F2"
            Panel.ZIndex="10">
      <StackPanel VerticalAlignment="Center"
                  HorizontalAlignment="Center">
        <Image x:Name="BootSplashIcon"
               Width="56"
               Height="56"
               HorizontalAlignment="Center"
               Stretch="Uniform"
               SnapsToDevicePixels="True"
               RenderOptions.BitmapScalingMode="HighQuality" />
        <TextBlock Margin="0,12,0,0"
                   FontSize="14"
                   FontFamily="Segoe UI, Malgun Gothic"
                   Foreground="#3C4043"
                   HorizontalAlignment="Center"
                   Text="캘린더 불러오는 중…" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
