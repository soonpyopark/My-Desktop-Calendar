<Window x:Class="MyDesktopCalendar.DesktopHostWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="My Desktop Calendar Host"
        Width="420"
        Height="260"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#202124"
        BorderThickness="0"
        ShowInTaskbar="False"
        ShowActivated="False"
        AllowsTransparency="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
  <Grid>
    <!--
      No WPF-level title bar/overlay here on purpose: embedded and unlocked must render
      pixel-identically. The drag handle lives inside the page itself (see wwwroot/index.html,
      "app-region: drag") via WebView2's native non-client-region support, enabled in
      InitWebViewAsync — no extra visual, nothing added to the window's chrome.
    -->
    <wv2:WebView2 x:Name="WebView" DefaultBackgroundColor="#FF202124" />
  </Grid>
</Window>
