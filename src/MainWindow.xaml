<Window x:Class="MyDesktopCalendar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="My Desktop Calendar — embed experiment"
        Width="420" Height="460"
        WindowStartupLocation="CenterScreen">
  <StackPanel Margin="20" VerticalAlignment="Center">
    <TextBlock Text="My Desktop Calendar — desktop embed experiment"
               FontSize="16" FontWeight="Bold" Margin="0,0,0,4" TextWrapping="Wrap"/>
    <TextBlock Text="Tests SysListView32 parenting (xdiary-style) with a Progman-raised fallback."
               Foreground="Gray" TextWrapping="Wrap" Margin="0,0,0,16"/>

    <TextBlock x:Name="StatusText" Text="Status: not embedded" FontWeight="SemiBold" Margin="0,0,0,12"/>

    <Button x:Name="EmbedButton" Content="Embed to Desktop" Height="32" Margin="0,0,0,8" Click="EmbedButton_Click"/>
    <Button x:Name="UndockButton" Content="Undock to Window" Height="32" Margin="0,0,0,8" Click="UndockButton_Click"/>
    <Button x:Name="OpenLogButton" Content="Open Diagnostics Log" Height="32" Margin="0,0,0,8" Click="OpenLogButton_Click"/>
    <Button x:Name="ExitButton" Content="Exit" Height="32" Margin="0,0,0,16" Click="ExitButton_Click"/>

    <TextBlock Text="Position / size (xdiary-style — works while embedded, no undock needed):"
               Foreground="Gray" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"/>
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <StackPanel Grid.Column="0" Margin="0,0,6,0">
        <TextBlock Text="Position" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
        <Button Content="▲" Width="40" Height="26" Margin="0,4,0,2" HorizontalAlignment="Center" Click="MoveUp_Click"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
          <Button Content="◀" Width="40" Height="26" Margin="0,0,4,0" Click="MoveLeft_Click"/>
          <Button Content="▶" Width="40" Height="26" Click="MoveRight_Click"/>
        </StackPanel>
        <Button Content="▼" Width="40" Height="26" Margin="0,2,0,0" HorizontalAlignment="Center" Click="MoveDown_Click"/>
      </StackPanel>

      <StackPanel Grid.Column="1" Margin="6,0,0,0">
        <TextBlock Text="Size" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,4">
          <TextBlock Text="W" VerticalAlignment="Center" Margin="0,0,6,0"/>
          <Button Content="−" Width="28" Height="26" Click="WidthMinus_Click"/>
          <Button Content="+" Width="28" Height="26" Margin="4,0,0,0" Click="WidthPlus_Click"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
          <TextBlock Text="H" VerticalAlignment="Center" Margin="0,0,6,0"/>
          <Button Content="−" Width="28" Height="26" Click="HeightMinus_Click"/>
          <Button Content="+" Width="28" Height="26" Margin="4,0,0,0" Click="HeightPlus_Click"/>
        </StackPanel>
      </StackPanel>
    </Grid>
  </StackPanel>
</Window>
