# My Desktop Calendar v1.1.8 — WPF 네이티브 셸
# 이 파일을 복사해 `.env`로 저장하세요.
# 읽는 위치: exe 옆, 또는 개발 시 프로젝트 루트 (위쪽으로 탐색)

# ---------------------------------------------------------------------------
# 관리자 로그인 (설정 / 로그인 화면)
# 우선순위: 환경 변수 → .env 의 MYCALENDAR_* → NEOCALENDAR_* → ADMIN_* → 기본값
# 앱 시작 시 admin 이 회원목록에 시드됩니다. 회원관리에서 바꾼 비밀번호가
# 이 .env 값보다 우선합니다 (members.json 해시).
# ---------------------------------------------------------------------------
MYCALENDAR_ADMIN_ID=admin
MYCALENDAR_ADMIN_PW=admin1234

# 하위 호환 별칭 (위 키가 없을 때만 사용)
# NEOCALENDAR_ADMIN_ID=admin
# NEOCALENDAR_ADMIN_PW=admin1234
# ADMIN_ID=admin
# ADMIN_PW=admin1234

# ---------------------------------------------------------------------------
# 공공데이터포털 특일 정보 API (대한민국 공휴일 동기화) — 선택
# ---------------------------------------------------------------------------
# DATA_GO_KR_SERVICE_KEY=

# ---------------------------------------------------------------------------
# 데이터 폴더 — 기본적으로 exe 옆 `data/` (개발 시 워크스페이스 `data/`)
# ---------------------------------------------------------------------------
# DATA_ROOT=data
# DATA_ROOT=D:/USB/my-calendar-data

# ---------------------------------------------------------------------------
# HTTP 웹 접속 — WPF 앱이 실행 중일 때 같은 데이터로 브라우저 접속
# 앱 시작 시 HOSTNAME 으로 Start Server 모드가 결정됩니다.
#   없음 / 127.0.0.1 → Start Server (local)  — http://127.0.0.1:3010/
#   0.0.0.0          → Start Server (Web)    — LAN 접속
# URL ACL (최초 1회, 관리자): scripts\add-urlacl.bat
#   또는 netsh http add urlacl url=http://+:3010/ user=Everyone
# 방화벽 인바운드 (LAN, 관리자): scripts\allow-firewall-inbound.bat
# ---------------------------------------------------------------------------
PORT=3010
HOSTNAME=127.0.0.1
# HOSTNAME=0.0.0.0
ALLOWED_HOSTS=*
